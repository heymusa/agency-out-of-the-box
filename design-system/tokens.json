{
  "$schema": "./tokens.schema.json",
  "name": "agency-out-of-the-box-tokens",
  "version": "0.1.0",
  "description": "Single source of truth for design tokens. Consumed by Tailwind configs in stacks/* and CSS variables on :root for shadcn primitives. Industry overlays in industries/{niche}/imagery.md may shift the brand-hue and fonts but cannot expand the scale.",

  "color": {
    "neutral": {
      "50":  "#fafafa",
      "100": "#f4f4f5",
      "200": "#e4e4e7",
      "300": "#d4d4d8",
      "400": "#a1a1aa",
      "500": "#71717a",
      "600": "#52525b",
      "700": "#3f3f46",
      "800": "#27272a",
      "900": "#18181b",
      "950": "#09090b"
    },
    "brand": {
      "_default": "blue",
      "_options": ["blue", "indigo", "emerald", "rose", "amber", "slate"],
      "blue": {
        "50":  "#eff6ff",
        "100": "#dbeafe",
        "200": "#bfdbfe",
        "300": "#93c5fd",
        "400": "#60a5fa",
        "500": "#3b82f6",
        "600": "#2563eb",
        "700": "#1d4ed8",
        "800": "#1e40af",
        "900": "#1e3a8a",
        "950": "#172554"
      },
      "indigo": {
        "50":  "#eef2ff",
        "100": "#e0e7ff",
        "200": "#c7d2fe",
        "300": "#a5b4fc",
        "400": "#818cf8",
        "500": "#6366f1",
        "600": "#4f46e5",
        "700": "#4338ca",
        "800": "#3730a3",
        "900": "#312e81",
        "950": "#1e1b4b"
      },
      "emerald": {
        "50":  "#ecfdf5",
        "100": "#d1fae5",
        "200": "#a7f3d0",
        "300": "#6ee7b7",
        "400": "#34d399",
        "500": "#10b981",
        "600": "#059669",
        "700": "#047857",
        "800": "#065f46",
        "900": "#064e3b",
        "950": "#022c22"
      },
      "rose": {
        "50":  "#fff1f2",
        "100": "#ffe4e6",
        "200": "#fecdd3",
        "300": "#fda4af",
        "400": "#fb7185",
        "500": "#f43f5e",
        "600": "#e11d48",
        "700": "#be123c",
        "800": "#9f1239",
        "900": "#881337",
        "950": "#4c0519"
      },
      "amber": {
        "50":  "#fffbeb",
        "100": "#fef3c7",
        "200": "#fde68a",
        "300": "#fcd34d",
        "400": "#fbbf24",
        "500": "#f59e0b",
        "600": "#d97706",
        "700": "#b45309",
        "800": "#92400e",
        "900": "#78350f",
        "950": "#451a03"
      },
      "slate": {
        "50":  "#f8fafc",
        "100": "#f1f5f9",
        "200": "#e2e8f0",
        "300": "#cbd5e1",
        "400": "#94a3b8",
        "500": "#64748b",
        "600": "#475569",
        "700": "#334155",
        "800": "#1e293b",
        "900": "#0f172a",
        "950": "#020617"
      }
    },
    "success": { "100": "#dcfce7", "500": "#22c55e", "600": "#16a34a" },
    "warning": { "100": "#fef3c7", "500": "#f59e0b", "600": "#d97706" },
    "error":   { "100": "#fee2e2", "500": "#ef4444", "600": "#dc2626" }
  },

  "font": {
    "heading": "'Inter Tight', system-ui, -apple-system, sans-serif",
    "body":    "'Inter', system-ui, -apple-system, sans-serif",
    "mono":    "'Geist Mono', ui-monospace, 'SF Mono', Menlo, monospace"
  },

  "fontSize": {
    "xs":   ["0.75rem",  "1rem"],
    "sm":   ["0.875rem", "1.25rem"],
    "base": ["1rem",     "1.5rem"],
    "lg":   ["1.125rem", "1.75rem"],
    "xl":   ["1.25rem",  "1.75rem"],
    "2xl":  ["1.5rem",   "2rem"],
    "3xl":  ["1.875rem", "2.25rem"],
    "4xl":  ["2.25rem",  "2.5rem"],
    "5xl":  ["3rem",     "1.1"],
    "6xl":  ["3.75rem",  "1.05"],
    "7xl":  ["4.5rem",   "1"]
  },

  "fontWeight": {
    "normal":   "400",
    "medium":   "500",
    "semibold": "600",
    "bold":     "700",
    "extrabold":"800"
  },

  "spacing": {
    "0":   "0",
    "1":   "0.25rem",
    "2":   "0.5rem",
    "3":   "0.75rem",
    "4":   "1rem",
    "5":   "1.25rem",
    "6":   "1.5rem",
    "8":   "2rem",
    "10":  "2.5rem",
    "12":  "3rem",
    "16":  "4rem",
    "20":  "5rem",
    "24":  "6rem",
    "32":  "8rem",
    "40":  "10rem",
    "48":  "12rem",
    "64":  "16rem"
  },

  "radius": {
    "none": "0",
    "sm":   "0.25rem",
    "md":   "0.5rem",
    "lg":   "0.75rem",
    "xl":   "1rem",
    "2xl":  "1.5rem",
    "full": "9999px"
  },

  "shadow": {
    "none": "none",
    "sm":   "0 1px 2px 0 rgb(0 0 0 / 0.05)",
    "md":   "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)",
    "lg":   "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)",
    "xl":   "0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1)"
  },

  "breakpoint": {
    "sm":  "640px",
    "md":  "768px",
    "lg":  "1024px",
    "xl":  "1280px",
    "2xl": "1536px"
  },

  "zIndex": {
    "behind":   "-1",
    "base":     "0",
    "dropdown": "10",
    "sticky":   "20",
    "overlay":  "30",
    "modal":    "40",
    "popover":  "50",
    "toast":    "60"
  },

  "_doctrine": {
    "spacing-grid": "All spacing maps to a 4px base. Never use arbitrary values like p-[7px].",
    "max-fonts":    "Two font families maximum (heading + body). Mono optional for code.",
    "max-type-sizes-per-block": 3,
    "max-colors-per-block":     3,
    "min-contrast-body":        "4.5:1 (WCAG AA)",
    "min-contrast-large-text":  "3:1 (WCAG AA)",
    "button-states": ["default", "hover", "focus-visible", "disabled", "loading"]
  }
}
