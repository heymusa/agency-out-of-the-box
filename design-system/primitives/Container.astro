---
/**
 * Container — token-bound max-width + horizontal-padding wrapper.
 */

interface Props {
  size?: 'sm' | 'md' | 'lg' | 'xl' | 'full';
  className?: string;
}

const { size = 'lg', className = '' } = Astro.props as Props;

const sizes = {
  sm:   'max-w-3xl',
  md:   'max-w-5xl',
  lg:   'max-w-7xl',
  xl:   'max-w-[88rem]',
  full: 'max-w-none',
};
---

<div class={`mx-auto px-6 lg:px-8 ${sizes[size]} ${className}`}>
  <slot />
</div>
