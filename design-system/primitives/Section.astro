---
/**
 * Section — token-bound vertical-padding wrapper.
 * Use for any page section that isn't a block from blocks/.
 */

interface Props {
  size?: 'tight' | 'standard' | 'large' | 'hero';
  background?: 'default' | 'neutral' | 'brand-soft' | 'inverse';
  className?: string;
  id?: string;
}

const { size = 'standard', background = 'default', className = '', id } = Astro.props as Props;

const sizes = {
  tight:    'py-12 lg:py-16',
  standard: 'py-16 lg:py-24',
  large:    'py-24 lg:py-32',
  hero:     'py-24 lg:py-40',
};

const backgrounds = {
  default:    'bg-white text-neutral-900',
  neutral:    'bg-neutral-50 text-neutral-900',
  'brand-soft': 'bg-brand-50 text-neutral-900',
  inverse:    'bg-neutral-900 text-neutral-100',
};
---

<section id={id} class={`w-full ${backgrounds[background]} ${sizes[size]} ${className}`}>
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <slot />
  </div>
</section>
