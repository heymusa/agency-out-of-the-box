---
/**
 * Button — primitive with full state coverage
 * States: default, hover, focus-visible, disabled, loading
 * Variants: primary, secondary, ghost, destructive
 * trackingId wires automatic cta_clicked analytics events.
 */

interface Props {
  variant?: 'primary' | 'secondary' | 'ghost' | 'destructive';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
  loading?: boolean;
  trackingId?: string;
  fullWidth?: boolean;
  className?: string;
  ariaLabel?: string;
}

const {
  variant = 'primary',
  size = 'md',
  href,
  type = 'button',
  disabled = false,
  loading = false,
  trackingId,
  fullWidth = false,
  className = '',
  ariaLabel,
} = Astro.props as Props;

const base =
  'inline-flex items-center justify-center gap-2 rounded-lg font-semibold transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 disabled:opacity-50 disabled:cursor-not-allowed';

const variants = {
  primary: 'bg-brand-600 hover:bg-brand-700 active:bg-brand-800 text-white focus-visible:ring-brand-600',
  secondary: 'border border-neutral-300 hover:border-neutral-400 hover:bg-neutral-50 text-neutral-700 focus-visible:ring-neutral-400',
  ghost: 'text-brand-700 hover:text-brand-800 hover:bg-brand-50 focus-visible:ring-brand-400',
  destructive: 'bg-error-600 hover:bg-error-500 text-white focus-visible:ring-error-500',
};

const sizes = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-3 text-base',
  lg: 'px-8 py-4 text-base',
};

const widthClass = fullWidth ? 'w-full' : '';
const allClasses = `${base} ${variants[variant]} ${sizes[size]} ${widthClass} ${className}`;
const isDisabled = disabled || loading;
---

{href ? (
  <a
    href={isDisabled ? undefined : href}
    aria-disabled={isDisabled}
    aria-label={ariaLabel}
    data-tracking-id={trackingId}
    class={allClasses}
    role={isDisabled ? 'button' : undefined}
  >
    {loading && (
      <svg class="animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24" aria-hidden="true">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.4 0 0 5.4 0 12h4zm2 5.3A8 8 0 014 12H0c0 3 1.1 5.8 3 7.9l3-2.6z" />
      </svg>
    )}
    <slot />
  </a>
) : (
  <button
    type={type}
    disabled={isDisabled}
    aria-label={ariaLabel}
    data-tracking-id={trackingId}
    class={allClasses}
  >
    {loading && (
      <svg class="animate-spin w-4 h-4" fill="none" viewBox="0 0 24 24" aria-hidden="true">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.4 0 0 5.4 0 12h4zm2 5.3A8 8 0 014 12H0c0 3 1.1 5.8 3 7.9l3-2.6z" />
      </svg>
    )}
    <slot />
  </button>
)}
