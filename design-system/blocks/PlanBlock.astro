---
/**
 * PlanBlock — StoryBrand 3-4-step plan.
 * Each step: verb-led, time-bound where possible, one-sentence detail.
 */

interface Step {
  number: number;
  title: string;
  body: string;
  timeframe?: string; // e.g. "Day 1-7" or "Week 2"
}

interface Props {
  heading: string;
  subheading?: string;
  steps: Step[]; // 3 or 4 only
}

const { heading, subheading, steps } = Astro.props as Props;
---

<section class="w-full bg-neutral-50">
  <div class="mx-auto max-w-7xl px-6 lg:px-8 py-24 lg:py-32">
    <div class="max-w-3xl mx-auto text-center mb-16">
      <h2 class="text-4xl lg:text-5xl font-extrabold tracking-tight text-neutral-900">{heading}</h2>
      {subheading && (
        <p class="mt-6 text-lg text-neutral-600 leading-relaxed">{subheading}</p>
      )}
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 max-w-6xl mx-auto">
      {steps.map((step) => (
        <div class="relative">
          <div class="w-12 h-12 rounded-full bg-brand-600 text-white flex items-center justify-center text-xl font-extrabold mb-6">
            {step.number}
          </div>
          {step.timeframe && (
            <p class="text-xs font-semibold uppercase tracking-wider text-brand-700 mb-2">
              {step.timeframe}
            </p>
          )}
          <h3 class="text-xl font-bold text-neutral-900">{step.title}</h3>
          <p class="mt-3 text-base text-neutral-600 leading-relaxed">{step.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
