---
/**
 * SocialProof — three variants
 * - logos: 4-6 client logos in a strip
 * - quote: single attributed testimonial with photo
 * - metrics: 3-up metric grid
 *
 * All content from props. Real proof only — quotes have attribution, metrics tie to agency-context.md §11.
 */

interface LogoItem {
  src: string;
  alt: string;
  href?: string;
}

interface QuoteAuthor {
  name: string;
  role: string;
  company: string;
  photo?: string;
}

interface Quote {
  text: string;
  author: QuoteAuthor;
}

interface Metric {
  value: string;
  label: string;
}

interface Props {
  variant: 'logos' | 'quote' | 'metrics';
  heading?: string;
  logos?: LogoItem[];
  quote?: Quote;
  metrics?: Metric[];
}

const { variant, heading, logos, quote, metrics } = Astro.props as Props;
---

<section class="w-full bg-neutral-50">
  <div class="mx-auto max-w-7xl px-6 lg:px-8 py-16 lg:py-20">
    {heading && (
      <p class="text-sm font-medium text-neutral-500 text-center uppercase tracking-wider mb-10">
        {heading}
      </p>
    )}

    {variant === 'logos' && logos && (
      <div class="flex flex-wrap items-center justify-center gap-x-12 gap-y-8 lg:gap-x-16">
        {logos.map((logo) => (
          logo.href ? (
            <a href={logo.href} class="block" aria-label={logo.alt}>
              <img src={logo.src} alt={logo.alt} class="h-10 lg:h-12 opacity-70 hover:opacity-100 transition-opacity" loading="lazy" />
            </a>
          ) : (
            <img src={logo.src} alt={logo.alt} class="h-10 lg:h-12 opacity-70" loading="lazy" />
          )
        ))}
      </div>
    )}

    {variant === 'quote' && quote && (
      <figure class="max-w-3xl mx-auto text-center">
        <blockquote class="text-xl lg:text-2xl font-medium text-neutral-800 leading-relaxed">
          "{quote.text}"
        </blockquote>
        <figcaption class="mt-8 flex items-center justify-center gap-4">
          {quote.author.photo && (
            <img
              src={quote.author.photo}
              alt={`Photo of ${quote.author.name}`}
              class="w-14 h-14 rounded-full object-cover"
              loading="lazy"
            />
          )}
          <div class="text-left">
            <p class="font-semibold text-neutral-900">{quote.author.name}</p>
            <p class="text-sm text-neutral-600">
              {quote.author.role}, {quote.author.company}
            </p>
          </div>
        </figcaption>
      </figure>
    )}

    {variant === 'metrics' && metrics && (
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-12 max-w-4xl mx-auto">
        {metrics.map((metric) => (
          <div class="text-center">
            <p class="text-5xl lg:text-6xl font-extrabold text-brand-600 tracking-tight">
              {metric.value}
            </p>
            <p class="mt-3 text-base text-neutral-700">{metric.label}</p>
          </div>
        ))}
      </div>
    )}
  </div>
</section>
